# Copy to `.env.server` (gitignored) for local Wasp dev.

# PostgreSQL connection string. Options, easiest first:
#   1. `wasp start db` (needs Docker) — Wasp runs + wires a dev Postgres for you.
#   2. A Railway Postgres URL (the v1 production target).
#   3. Any local Postgres (Postgres.app, Homebrew, etc.).
DATABASE_URL=postgresql://user:password@localhost:5432/dotflowy

# Dev convenience: lets a fresh signup log in without clicking the emailed
# verification link. The Dummy email sender prints that link to the server log.
SKIP_EMAIL_VERIFICATION_IN_DEV=true
