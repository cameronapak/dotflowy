{
  "name": "dotflowy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dotflowy outline editor on Wasp (React + Node + Prisma), deployed to Railway. Migrating from TanStack Start + Cloudflare — see docs/PRD-wasp-migration.md.",
  "license": "MIT",
  "workspaces": [
    ".wasp/out/*",
    ".wasp/out/sdk/wasp"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.12.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@wasp.sh/spec": "file:.wasp/spec/",
    "prisma": "5.19.1",
    "typescript": "5.9.3",
    "vite": "^7.0.6",
    "vitest": "^4.0.16"
  }
}
