{
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/create-worktree.sh",
            "timeout": 600,
            "statusMessage": "Installing deps and applying the local D1 schema..."
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/remove-worktree.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
